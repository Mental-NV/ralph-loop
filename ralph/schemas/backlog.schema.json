{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Mental-NV/Clawd-Net/backlog.schema.json",
  "title": "ClawdNet Backlog Schema",
  "description": "Schema for the ClawdNet execution backlog",
  "type": "object",
  "required": ["version", "items"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "items": {
      "type": "array",
      "description": "List of backlog items (milestones)",
      "items": {
        "$ref": "#/definitions/backlogItem"
      }
    }
  },
  "definitions": {
    "backlogItem": {
      "type": "object",
      "required": ["id", "title", "status", "priority", "order"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique stable identifier (kebab-case)",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "description": "Human-readable title",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["todo", "in_progress", "ready_for_validation", "done", "blocked", "deferred", "cancelled"],
          "description": "Current status of the item"
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "P3"],
          "description": "Priority level"
        },
        "order": {
          "type": "integer",
          "description": "Execution order (unique, ascending)",
          "minimum": 0
        },
        "dependsOn": {
          "type": "array",
          "description": "List of item IDs this depends on",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "why": {
          "type": "string",
          "description": "Rationale for this item"
        },
        "deliverables": {
          "type": "array",
          "description": "List of deliverable items",
          "items": {
            "$ref": "#/definitions/checklistItem"
          },
          "default": []
        },
        "risks": {
          "type": "array",
          "description": "List of risks",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "exitCriteria": {
          "type": "array",
          "description": "List of exit criteria",
          "items": {
            "$ref": "#/definitions/checklistItem"
          },
          "default": []
        },
        "validation": {
          "type": "object",
          "description": "Validation configuration",
          "properties": {
            "commands": {
              "type": "array",
              "description": "Commands to run for validation",
              "items": {
                "type": "string"
              },
              "default": []
            }
          }
        },
        "startedAt": {
          "type": "string",
          "description": "ISO 8601 timestamp when item was started",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "description": "ISO 8601 timestamp when item was completed",
          "format": "date-time"
        },
        "blockedReason": {
          "type": "string",
          "description": "Reason for blocked status (required if status is blocked)"
        },
        "commitMessage": {
          "type": "string",
          "description": "Commit message for completed item"
        },
        "artifacts": {
          "type": "object",
          "description": "Artifacts produced by this item",
          "properties": {
            "docs": {
              "type": "array",
              "description": "Documentation files created/updated",
              "items": {
                "type": "string"
              }
            },
            "planFile": {
              "type": "string",
              "description": "Execution plan file (e.g., PLAN-XX.md)"
            }
          }
        }
      }
    },
    "checklistItem": {
      "type": "object",
      "required": ["id", "text", "done"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier within the parent item",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "text": {
          "type": "string",
          "description": "Checklist item text",
          "minLength": 1
        },
        "done": {
          "type": "boolean",
          "description": "Whether this item is complete"
        }
      }
    }
  }
}
